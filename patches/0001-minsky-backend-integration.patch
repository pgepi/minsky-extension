+import { apiKeyStorage } from "@/utils/storage";
 import { ApiPrompt, ApiPromptDetail, Category, Prompt, PromptsResponse } from "./types";
 
-const API_URL = "https://prompts.chat/prompts.json";
-const PROMPT_DETAIL_URL = (id: string) => `https://prompts.chat/api/prompts/${id}`;
+const MINSKY_BASE_URL = "https://minsky.pge.pi.gov.br";
+const API_URL = `${MINSKY_BASE_URL}/prompts.json`;
+const PROMPT_DETAIL_URL = (id: string) => `${MINSKY_BASE_URL}/api/prompts/${id}`;
+
+// Thrown when no API key has been configured yet in the extension settings.
+export class ApiKeyRequiredError extends Error {
+  constructor() {
+    super("API key not configured");
+    this.name = "ApiKeyRequiredError";
+  }
+}
+
+// Thrown when the configured key was rejected by Minsky (revoked, wrong, etc).
+export class ApiKeyInvalidError extends Error {
+  constructor() {
+    super("API key invalid or unauthorized");
+    this.name = "ApiKeyInvalidError";
+  }
+}
+
+async function authenticatedFetch(url: string): Promise<Response> {
+  const apiKey = await apiKeyStorage.getValue();
+  if (!apiKey) {
+    throw new ApiKeyRequiredError();
+  }
+
+  const response = await fetch(url, { headers: { PROMPTS_API_KEY: apiKey } });
+
+  // A missing/invalid key never reaches the route handler - Minsky's auth
+  // gate either 401s (API routes) or redirects to /login (page routes),
+  // which `fetch` follows transparently, so `redirected` is the tell.
+  if (response.status === 401 || response.status === 403 || response.redirected) {
+    throw new ApiKeyInvalidError();
+  }
+
+  return response;
+}
 
 let cachedPrompts: Prompt[] | null = null;
 let cachedCategories: Category[] | null = null;
